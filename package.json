{
  "name": "programa-xml-em-lote-nfse",
  "version": "1.0.0",
  "description": "Ferramenta local para download em lote de XMLs de NFS-e Nacional via mTLS",
  "main": "server.js",
  "scripts": {
    "build:panels": "node scripts/build-panels-bundle.js",
    "build:assets": "node scripts/build-assets-bundle.js",
    "build": "npm run build:panels && npm run build:assets",
    "prestart": "npm run build",
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test"
  },
  "keywords": [
    "nfse",
    "xml",
    "lote",
    "nsu",
    "mtls",
    "download"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.8",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "node-forge": "^1.4.0"
  },
  "overrides": {
    "exceljs": {
      "uuid": "11.1.1"
    }
  }
}
