SUPABASE_URL=https://tdmzgjxugwpqproqtzph.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_APP_SECRET=...
CERT_ENCRYPTION_KEY=64_hex_chars_generated_locally
AUTH_ALLOWED_EMAILS=email1@suaempresa.com.br,email2@suaempresa.com.br
AUTH_ALLOWED_DOMAINS=suaempresa.com.br
# Alternative to allowlists: add app_metadata.xml_nfse_role = admin|operator|viewer to authorized users.
AUTH_REQUIRE_XML_NFSE_ROLE=false
AUTH_ALLOW_ALL_SUPABASE_USERS=false
# Required only when /api/scheduler-cron is called by an external scheduler.
SCHEDULER_SECRET=generate_a_long_random_secret
# TLS validation stays enabled by default. Use false only for a short, diagnosed test.
NFSE_TLS_REJECT_UNAUTHORIZED=true

# Optional legacy Basic Auth. Supabase Auth is preferred.
# APP_ACCESS_USER=admin
# APP_ACCESS_PASSWORD=change_this_password

# Optional fallback certificate, not required when using upload via interface.
# NFSE_CERT_PFX_BASE64=...
# NFSE_CERT_PASSPHRASE=...
# NFSE_CERT_CNPJ=...
# NFSE_CERT_ID=vercel-env-cert
# NFSE_CERT_NAME=certificado-vercel.pfx
