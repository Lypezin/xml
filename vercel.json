{
  "version": 2,
  "framework": null,
  "regions": ["gru1"],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/scheduler-cron/0",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/1",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/2",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/3",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/4",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/5",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/scheduler-cron/6",
      "schedule": "0 8 * * *"
    }
  ]
}
